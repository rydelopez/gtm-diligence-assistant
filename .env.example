# VDR Bench Configuration

# Copy this file to .env and fill in your API keys

# API Keys
# Required: at least one LLM provider.
# Optional: Tavily for the legacy benchmark harness, LangSmith for tracing/evals.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
TAVILY_API_KEY=
LANGSMITH_API_KEY=

# LangSmith Tracing
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=

# Take-home Docker runtime
DATASET_JSONL=/inputs/diligence_eval_examples.jsonl
DATAROOM_ROOT=/data
VECTOR_INDEX_CACHE_DIR=/outputs/vector_indexes
OUT_JSONL=/outputs/gtm_diligence_results.jsonl
OUT_SUMMARY_JSON=/outputs/gtm_diligence_summary.json
UI_DIST_DIR=/opt/gtm-ui-dist
WEB_HOST=0.0.0.0
WEB_PORT=8000

# Legacy benchmark harness
INPUT_XLSX=/inputs/input.xlsx # path to input spreadsheet
INPUT_SHEET=Queries # sheet name containing queries
OUT_CSV=/outputs/harness_results.csv # path to output csv

# Harness Parameters
ACC_RUBRIC_W=0.7 # Weight for rubric checks (navigation, evidence, formatting). Default: 70%
ACC_ANSWER_CORRECTNESS_W=0.3 # Weight for final answer correctness. Default: 30%
MODEL=openai # openai, anthropic, google
OPENAI_MODEL=gpt-5-mini
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
GOOGLE_MODEL=gemini-2.5-pro
EMBEDDING_PROVIDER=openai # openai, google, fake
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
GOOGLE_EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_CHUNK_SIZE=16
EMBEDDING_DOC_MAX_CHARS=12000
EMBEDDING_ADD_BATCH_SIZE=8
EMBEDDING_BATCH_MAX_RETRIES=4
EMBEDDING_BATCH_BACKOFF_SECONDS=2
MODEL_TEMPERATURE=0 # (0.0 = deterministic, >1.0 = more creative)
